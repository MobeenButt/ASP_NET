@model IEnumerable<Lms.Models.Lesson>

<header class="lms-pagehead">
    <div>
        <div class="lms-pagehead__k">Course</div>
        <h2 class="lms-pagehead__h mb-0">Lessons</h2>
        <div class="text-muted">Course ID: @ViewBag.CourseId</div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Course" asp-action="Index" class="btn btn-outline-secondary">Back to Courses</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create"
               asp-route-courseId="@ViewBag.CourseId"
               class="btn btn-primary">Add Lesson</a>
        }
    </div>
</header>

@if (Model is null || !Model.Any())
{
    <div class="empty-state">
        <h4 class="mb-2">No lessons yet</h4>
        <div class="text-muted">Lessons created for this course will appear here.</div>
    </div>
}
else
{
    <section class="admin-card" aria-label="Lessons list">
        <div class="admin-card__body">
            <div class="table-responsive lms-tablewrap">
                <table class="table align-middle mb-0 lms-table">
                    <thead>
                        <tr>
                            <th style="width: 25%">Lesson Title</th>
                            <th>Content</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lesson in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@lesson.Title</td>
                                <td class="text-muted">@lesson.Content</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </section>
}
