@using Microsoft.AspNetCore.Identity
@using Lms.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav lms-auth">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link lms-link" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <span class="lms-auth__hello">Hello</span> <span class="lms-auth__name">@User.Identity?.Name</span>
        </a>
    </li>
    <li class="nav-item">
        <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link lms-link lms-link--btn">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link lms-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link lms-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>

