@model IEnumerable<Lms.Models.Course>

<header class="lms-pagehead">
    <div>
        <div class="lms-pagehead__k">Catalog</div>
        <h2 class="lms-pagehead__h mb-0">Courses</h2>
        <div class="text-muted">Browse courses and jump into lessons.</div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <a asp-controller="Course" asp-action="Create" class="btn btn-primary">Create Course</a>
    }
</header>

<form method="get" asp-action="Index">
    <div class="row">
        <div class="col-md-4">
            <input type="text"
                   name="search"
                   placeholder="Search course..."
                   class="form-control" />
        </div>

        <div class="col-md-4">
            <select name="categoryId"
                    class="form-control">
                <option value="">All Categories</option>

                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">
                Search
            </button>
        </div>
    </div>
</form>

<br />

@if (TempData["Message"] is string msg)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model is null || !Model.Any())
{
    <div class="empty-state">
        <h4 class="mb-2">No courses found</h4>
        <div class="text-muted">Once courses are created, they’ll appear here.</div>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var course in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <article class="card shadow-sm h-100 lms-course">
                    <div class="card-body">
                        <div class="lms-course__top">
                            <h5 class="card-title mb-1 lms-course__title">@course.Title</h5>
                            @if (course.Category is not null)
                            {
                                <span class="lms-tag">@course.Category.Name</span>
                            }
                        </div>

                        <p class="card-text text-muted mb-3 lms-course__desc">@course.Description</p>

                        <div class="d-flex flex-wrap gap-2">
                            <a asp-controller="Course"
                               asp-action="Details"
                               asp-route-id="@course.Id"
                               class="btn btn-outline-secondary">
                                View Details
                            </a>

                            <a asp-controller="Lesson"
                               asp-action="Index"
                               asp-route-courseId="@course.Id"
                               class="btn btn-outline-primary">
                                View Lessons
                            </a>

                            @if (User.IsInRole("Student") && !User.IsInRole("Admin"))
                            {
                                <form asp-controller="Enrollment"
                                      asp-action="RequestEnrollment"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="courseId" value="@course.Id" />
                                    <button type="submit" class="btn btn-success">Enroll</button>
                                </form>
                            }
                        </div>
                    </div>
                </article>
            </div>
        }
    </div>
}
