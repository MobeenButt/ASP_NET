@model IEnumerable<Lms.Models.Course>

<h2>Courses</h2>

@if (User.IsInRole("Admin"))
{
    <a asp-action="Create" class="btn btn-primary">Create Course</a>
}

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var course in Model)
        {
            <tr>
                <td>@course.Title</td>
                <td>@course.Description</td>
            </tr>
        }
    </tbody>
</table>